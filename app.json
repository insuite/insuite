{
  "expo": {
    "name": "INSUITE2",
    "slug": "INSUITE2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "insuite2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.insuite.invite",
      "usesAppleSignIn": true,
      "infoPlist": {
        "UIUserInterfaceStyle": "Dark",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.insuite.invite"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#0f0e0c",
          "dark": {
            "backgroundColor": "#0f0e0c"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow InSuite to access your photos so you can set a profile picture.",
          "cameraPermission": "Allow InSuite to use your camera to take a profile picture."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#c9b98a"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "61329890-3b48-4385-a1cc-f9771d131111"
      }
    },
    "owner": "julihan"
  }
}
